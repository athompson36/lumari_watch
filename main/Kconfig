menu "Lumari"

config LUMARI_BOARD_QEMU
    bool "Target QEMU emulator (reduced resolution, stubbed peripherals)"
    default n
    help
        Selects the QEMU board profile: 198x240 display, stubbed touch/IMU/RTC.
        Set this for ANY QEMU build (both stub and real-framebuffer modes).

config LUMARI_QEMU
    bool "Use stub framebuffer (prebuilt QEMU without RGB device)"
    default n
    depends on LUMARI_BOARD_QEMU
    help
        When enabled, the QEMU RGB driver uses a heap-backed stub instead of the
        virtual device at 0x21000000. Use this with prebuilt QEMU (idf_tools).
        When disabled (but LUMARI_BOARD_QEMU is set), the real QEMU RGB device
        is used and an SDL window shows the framebuffer.

endmenu
