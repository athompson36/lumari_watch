*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# Debug / coverage
*.gcda
*.gcno
coverage.info
pytest_embedded_log/
pytest-embedded/

# Build summaries (optional)
build_summary_*.xml
app_info_*.txt
size_info*.txt
